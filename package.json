{
  "name": "nota-service-hp",
  "version": "1.0.0",
  "description": "Nota Service HP - Android Debug",
  "main": "index.html",
  "scripts": {
    "build": "mkdir -p www && cp src/index.html www/index.html",
    "cap:add": "cap add android",
    "cap:sync": "cap sync",
    "cap:open": "cap open android",
    "build:debug": "npm run build && cap sync android && cd android && ./gradlew assembleDebug",
    "install:apk": "adb install android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@capacitor/android": "^5.7.0",
    "@capacitor/core": "^5.7.0",
    "@capacitor/camera": "^5.2.0",
    "@capacitor/filesystem": "^5.2.0",
    "@capacitor/share": "^5.2.0",
    "@capacitor/contacts": "^5.2.0",
    "@capacitor-community/bluetooth-le": "^3.1.0",
    "@capacitor/splash-screen": "^5.2.0",
    "@capacitor/status-bar": "^5.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^5.7.0"
  }
}
