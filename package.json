- name: 📝 Fix package.json (Official Contacts)
        run: |
          cat > package.json << 'EOF'
          {
            "name": "nota-service-hp",
            "version": "1.0.0",
            "description": "Nota Service HP - Android Debug",
            "main": "index.html",
            "scripts": {
              "build": "mkdir -p www && cp src/index.html www/index.html",
              "cap:sync": "cap sync android",
              "build:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug"
            },
            "dependencies": {
              "@capacitor/android": "^5.7.0",
              "@capacitor/core": "^5.7.0",
              "@capacitor/camera": "^5.0.9",
              "@capacitor/filesystem": "^5.0.7",
              "@capacitor/share": "^5.0.7",
              "@capacitor/splash-screen": "^5.0.7",
              "@capacitor/status-bar": "^5.0.7",
              "@capacitor-community/contacts": "^5.0.0",
              "@capacitor-community/bluetooth-le": "^3.1.0"
            },
            "devDependencies": {
              "@capacitor/cli": "^5.7.0"
            }
          }
          EOF
