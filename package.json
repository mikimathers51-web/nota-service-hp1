{
  "name": "nota-service-hp",
  "version": "2.0.0",
  "description": "Nota Service HP - Capacitor 7",
  "main": "index.html",
  "scripts": {
    "build": "mkdir -p www && cp src/index.html www/index.html",
    "cap:add": "cap add android",
    "cap:sync": "cap sync",
    "cap:open": "cap open android",
    "build:debug": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug",
    "install:apk": "adb install android/app/build/outputs/apk/debug/app-debug.apk"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/filesystem": "^7.0.0",
    "@capacitor/share": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0",
    "@capacitor-community/contacts": "^7.0.0",
    "@capacitor-community/bluetooth-le": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0"
  }
}
